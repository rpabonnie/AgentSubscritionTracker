<!-- SPEC-0003 §5.2 — borderless, topmost, non-activating tooltip callout. -->
<Window x:Class="AgentSubscriptionTracker.App.Views.CalloutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AgentSubscriptionTracker.App.Views"
        xmlns:vm="clr-namespace:AgentSubscriptionTracker.App.ViewModels"
        Title="AgentSubscriptionTracker"
        Width="340"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <views:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <views:SeverityToBrushConverter x:Key="SeverityToBrush" />

        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource BarTrackBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CalloutBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProviderTemplate" DataType="{x:Type vm:ProviderViewModel}">
            <StackPanel Margin="0,6,0,6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right"
                               HorizontalAlignment="Right"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding PlanText}"
                               Visibility="{Binding PlanText, Converter={StaticResource NullToCollapsed}}" />
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="{Binding ProviderName}" />
                </DockPanel>

                <TextBlock Margin="0,3,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding StateMessage}"
                           TextWrapping="Wrap"
                           Visibility="{Binding StateMessage, Converter={StaticResource NullToCollapsed}}" />

                <ItemsControl ItemsSource="{Binding Bars}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:UsageBarViewModel}">
                            <Grid Margin="0,5,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0">
                                    <TextBlock DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="{Binding ValueText}" />
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding Label}" />
                                </DockPanel>

                                <ProgressBar Grid.Row="1"
                                             Height="4"
                                             Margin="0,3,0,0"
                                             Background="{DynamicResource BarTrackBrush}"
                                             BorderThickness="0"
                                             Foreground="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                             Maximum="100"
                                             Minimum="0"
                                             Value="{Binding PercentUsed, Mode=OneWay}" />

                                <TextBlock Grid.Row="2"
                                           Margin="0,2,0,0"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="{Binding ResetText}"
                                           Visibility="{Binding ResetText, Converter={StaticResource NullToCollapsed}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,5,0,0"
                           FontSize="10"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding FooterText}"
                           Visibility="{Binding FooterText, Converter={StaticResource NullToCollapsed}}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="12"
            Padding="14,10,14,10"
            Background="{DynamicResource CalloutBackgroundBrush}"
            BorderBrush="{DynamicResource CalloutBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.35" ShadowDepth="2" />
        </Border.Effect>

        <StackPanel>
            <TextBlock FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="AGENT SUBSCRIPTIONS" />

            <ContentControl Content="{Binding Claude}"
                            ContentTemplate="{StaticResource ProviderTemplate}"
                            Focusable="False" />

            <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" />

            <ContentControl Content="{Binding Copilot}"
                            ContentTemplate="{StaticResource ProviderTemplate}"
                            Focusable="False" />

            <DockPanel Margin="0,8,0,0" LastChildFill="True">
                <Button Click="OnExitClick"
                        Content="Exit"
                        DockPanel.Dock="Right"
                        Style="{StaticResource CommandButton}" />
                <Button Click="OnRefreshClick"
                        Content="Refresh"
                        DockPanel.Dock="Right"
                        Style="{StaticResource CommandButton}" />
                <TextBlock x:Name="AgeText"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
