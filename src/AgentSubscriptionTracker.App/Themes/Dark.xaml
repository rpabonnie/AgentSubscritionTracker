<!-- SPEC-0003 §5.4 — dark theme brushes for the callout. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="CalloutBackgroundBrush" Color="#FF1F2430" />
    <SolidColorBrush x:Key="CalloutBorderBrush" Color="#FF3A4153" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFEDEFF5" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF9AA3B5" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF6E8BFF" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFE0A53C" />
    <SolidColorBrush x:Key="CriticalBrush" Color="#FFE5534B" />
    <SolidColorBrush x:Key="BarTrackBrush" Color="#FF343B4D" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#FF2B3242" />

</ResourceDictionary>
